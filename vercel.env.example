APP_NAME=OptiBus
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.optibus.my.id
APP_KEY=
FORCE_HTTPS=true
TRUSTED_PROXIES=*

LOG_CHANNEL=stderr
CACHE_STORE=array
SESSION_DRIVER=cookie
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync

DB_CONNECTION=pgsql
# Prefer one connection string on Vercel:
# DB_URL=postgresql://DB_USER:DB_PASSWORD@DB_POOLER_HOST:6543/DB_NAME?sslmode=require&channel_binding=require
# Or use the split variables below:
# DB_HOST=
DB_PORT=6543
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
DB_SSLMODE=require

APP_SERVICES_CACHE=/tmp/storage/bootstrap/cache/services.php
APP_PACKAGES_CACHE=/tmp/storage/bootstrap/cache/packages.php
APP_CONFIG_CACHE=/tmp/storage/bootstrap/cache/config.php
APP_ROUTES_CACHE=/tmp/storage/bootstrap/cache/routes-v7.php
APP_EVENTS_CACHE=/tmp/storage/bootstrap/cache/events.php
